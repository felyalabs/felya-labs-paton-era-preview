---
import { developmentUpdatesForm, siteMetadata } from '../data/site.js';
import { defaultLocale, localeDetails, localePath, locales, resolveLocale, type Locale } from '../i18n/config';
import { t, translations } from '../i18n/translations';
import SiteScripts from '../components/SiteScripts.astro';
import '../styles/global.css';

const {
  locale: localeProp,
  title,
  lang,
  htmlClass = '',
  bodyClass = 'antialiased',
  includeSiteScript = false,
  includeOrganizationSchema = false,
  includeProductSchema = false,
  description,
  openGraphTitle,
  openGraphDescription,
  twitterTitle,
  twitterDescription,
  localizedHome = false,
  robots = 'index, follow, max-image-preview:large'
} = Astro.props;

const locale: Locale = resolveLocale(localeProp ?? lang ?? defaultLocale);
const resolvedTitle = title ?? t(locale, 'meta.title');
const resolvedDescription = description ?? t(locale, 'meta.description');
const resolvedOpenGraphTitle = openGraphTitle ?? t(locale, 'meta.ogTitle');
const resolvedOpenGraphDescription = openGraphDescription ?? t(locale, 'meta.ogDescription');
const resolvedTwitterTitle = twitterTitle ?? resolvedOpenGraphTitle;
const resolvedTwitterDescription = twitterDescription ?? resolvedOpenGraphDescription;

const siteOrigin = Astro.site?.origin ?? 'https://preview.felyalabs.com';
const canonicalPath = Astro.url.pathname === '/index.html' ? '/' : Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath, siteOrigin).toString();
const socialImageUrl = new URL('/assets/brand/felya-labs-paton-social-preview-1200x630.jpg', siteOrigin).toString();
const organizationLogoUrl = new URL('/assets/brand/felya-labs-logo-square-512.png', siteOrigin).toString();
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'FELYA LABS',
  url: siteOrigin,
  logo: organizationLogoUrl,
  email: 'info@felyalabs.com',
  sameAs: [
    'https://linkedin.com/company/felya-labs',
    'https://instagram.com/felya_labs/',
    'https://github.com/felyalabs/'
  ]
};
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'PATON',
  description: t(locale, 'system.leadControl'),
  brand: {
    '@type': 'Brand',
    name: 'FELYA LABS'
  },
  url: canonicalUrl
};

const styleSrc = import.meta.env.DEV ? "style-src 'self' 'unsafe-inline'" : "style-src 'self'";
const scriptSrc = import.meta.env.DEV ? "script-src 'self' 'unsafe-inline'" : "script-src 'self'";
const connectSrc = import.meta.env.DEV
  ? `connect-src 'self' ${developmentUpdatesForm.origin}`
  : `connect-src ${developmentUpdatesForm.origin}`;
const contentSecurityPolicy = `default-src 'self'; base-uri 'none'; object-src 'none'; ${scriptSrc}; script-src-attr 'none'; ${styleSrc}; font-src 'self'; img-src 'self'; media-src 'self'; manifest-src 'self'; ${connectSrc}; form-action ${developmentUpdatesForm.origin}; frame-src 'none'; upgrade-insecure-requests`;
---

<!DOCTYPE html>
<html lang={localeDetails[locale].htmlLang} class={htmlClass || undefined} data-theme="light" data-language={locale}>
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy}>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script is:inline src="/assets/js/theme-init.js"></script>
    <title>{resolvedTitle}</title>

    <meta name="description" content={resolvedDescription}>
    <meta name="robots" content={robots}>
    <link rel="canonical" href={canonicalUrl}>
    {localizedHome && locales.map((item) => (
      <link rel="alternate" hreflang={localeDetails[item].htmlLang} href={new URL(localePath(item), siteOrigin).toString()} />
    ))}
    {localizedHome && <link rel="alternate" hreflang="x-default" href={new URL(localePath(defaultLocale), siteOrigin).toString()} />}

    <meta property="og:type" content="website">
    <meta property="og:site_name" content={siteMetadata.siteName}>
    <meta property="og:locale" content={localeDetails[locale].ogLocale}>
    {localizedHome && locales.filter((item) => item !== locale).map((item) => <meta property="og:locale:alternate" content={localeDetails[item].ogLocale} />)}
    <meta property="og:title" content={resolvedOpenGraphTitle}>
    <meta property="og:description" content={resolvedOpenGraphDescription}>
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content={socialImageUrl}>
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content={t(locale, 'meta.imageAlt')}>

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={resolvedTwitterTitle}>
    <meta name="twitter:description" content={resolvedTwitterDescription}>
    <meta name="twitter:image" content={socialImageUrl}>
    <meta name="twitter:image:alt" content={t(locale, 'meta.imageAlt')}>

    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff">
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111111">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon/favicon-48x48.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
    <link rel="manifest" href="/assets/favicon/site.webmanifest">

    {includeOrganizationSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)}></script>
    )}
    {includeProductSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)}></script>
    )}
</head>
<body class={bodyClass}>
    {includeSiteScript && <div id="felya-i18n" hidden data-translations={JSON.stringify(translations[locale])}></div>}
    <slot />
    {includeSiteScript && <SiteScripts />}
</body>
</html>
