---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/translations';
const { locale } = Astro.props as { locale: Locale };
---

<section id="contact" class="contact-section section-shell section-nav-target" aria-labelledby="contact-heading">
    <div class="section-inner">
        <div class="contact-invitation reveal-block">
            <p class="section-kicker" data-i18n="workWithUs.eyebrow">{t(locale, 'workWithUs.eyebrow')}</p>
            <h2 id="contact-heading" class="contact-title section-nav-target" data-i18n="workWithUs.heading" set:html={t(locale, 'workWithUs.heading')}></h2>
            <p class="contact-description" data-i18n="workWithUs.description">{t(locale, 'workWithUs.description')}</p>

            <div class="contact-paths">
                <a href="mailto:info@felyalabs.com" class="contact-path">
                    <strong data-i18n="workWithUs.partnerTitle">{t(locale, 'workWithUs.partnerTitle')}</strong>
                    <span data-i18n="workWithUs.partnerDescription">{t(locale, 'workWithUs.partnerDescription')}</span>
                </a>
                <a href="mailto:info@felyalabs.com" class="contact-path">
                    <strong data-i18n="workWithUs.joinTitle">{t(locale, 'workWithUs.joinTitle')}</strong>
                    <span data-i18n="workWithUs.joinDescription">{t(locale, 'workWithUs.joinDescription')}</span>
                </a>
            </div>

            <div class="contact-closing">
                <p data-i18n="workWithUs.openInvitation">{t(locale, 'workWithUs.openInvitation')}</p>
                <a href="mailto:info@felyalabs.com">info@felyalabs.com</a>
            </div>
        </div>
    </div>
</section>
