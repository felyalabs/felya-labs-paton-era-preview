---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/translations';
const { locale } = Astro.props as { locale: Locale };
---

<button type="button" data-theme-toggle class="theme-toggle" aria-label={t(locale, 'theme.toDark')} aria-pressed="false">
    <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
        <svg focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3.7"/>
            <g opacity="0.82">
                <path d="M12 2.25v1.9"/>
                <path d="M12 19.85v1.9"/>
                <path d="m5.1 5.1 1.34 1.34"/>
                <path d="m17.56 17.56 1.34 1.34"/>
                <path d="M2.25 12h1.9"/>
                <path d="M19.85 12h1.9"/>
                <path d="m6.44 17.56-1.34 1.34"/>
                <path d="m18.9 5.1-1.34 1.34"/>
            </g>
        </svg>
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
        <svg focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M20.2 14.65A7.9 7.9 0 0 1 9.35 3.8a8.4 8.4 0 1 0 10.85 10.85Z"
                  fill="currentColor"/>
            <path d="M17.8 15.2A8.4 8.4 0 0 1 8.8 6.2"
                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.34"/>
        </svg>
    </span>
</button>
