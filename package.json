{
  "name": "felya-labs-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "verify:references": "node scripts/verify-repository.mjs",
    "verify:i18n": "node --experimental-strip-types scripts/verify-localizations.mjs",
    "verify:localized-build": "node --experimental-strip-types scripts/verify-localized-build.mjs",
    "review:i18n": "node --experimental-strip-types scripts/generate-localization-review.mjs",
    "verify": "node scripts/verify-repository.mjs && node --experimental-strip-types scripts/verify-localizations.mjs && astro build && node --experimental-strip-types scripts/verify-localized-build.mjs"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.3",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.2"
  }
}
